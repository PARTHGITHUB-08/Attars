# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/saurabh

# ── Frontend URL (for CORS) ───────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── JWT Secret — change this to a long random string in production ────────────
JWT_SECRET=replace-this-with-a-long-random-secret-in-production

# ── Admin Account (seeded on first run if no admin exists in DB) ───────────────
ADMIN_PASSWORD=Saurabh@2026!
ADMIN_EMAIL=your-admin-email@example.com

# ── Email (Nodemailer — optional, for invoice/reset emails) ───────────────────
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
